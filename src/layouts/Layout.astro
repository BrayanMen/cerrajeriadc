---
// Importaciones de fuentes y estilos globales
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "../styles/global.css";

// Props para SEO dinámico
export interface Props {
	title?: string;
	description?: string;
  canonicalURL?: string;
  image?: string;
}

// Valores por defecto para las props
const {
	title = "Cerrajero a Domicilio 24/7 | Cerrajería DC | CABA",
	description = "Servicio de cerrajero de urgencia 24 horas en Capital Federal. Apertura de puertas, autos y cajas fuertes sin daños. ¡Llegamos en 20 minutos!",
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  image = new URL("/logo.png", Astro.site).href,
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<!-- Google Tag Manager -->
		<script type="text/partytown">
			(function (w, d, s, l, i) {
				w[l] = w[l] || [];
				w[l].push({
					"gtm.start": new Date().getTime(),
					event: "gtm.js",
				});
				var f = d.getElementsByTagName(s)[0],
					j = d.createElement(s),
					dl = l != "dataLayer" ? "&l=" + l : "";
				j.async = true;
				j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
				f.parentNode.insertBefore(j, f);
			})(window, document, "script", "dataLayer", "GTM-TJNJQV5B");
		</script>
		<!-- End Google Tag Manager -->
		<!-- Google tag (gtag.js) -->
		<script
			type="text/partytown"
			async
			src="https://www.googletagmanager.com/gtag/js?id=G-7QJJ3S16JK"
		></script>
		<script type="text/partytown">
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("js", new Date());

			gtag("config", "G-7QJJ3S16JK");
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<!-- SEO Básico y Optimizado -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		<meta name="robots" content="index, follow, max-image-preview:large" />
		<meta name="author" content="Cerrajeria DC" />

		<!-- Preconexiones para mejorar rendimiento -->
		<link rel="preconnect" href="https://www.googletagmanager.com" />
		<link rel="dns-prefetch" href="https://www.google-analytics.com" />
		<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
		<link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

		<link rel="icon" type="image/svg+xml" href="/logo.png" />

		<!-- Open Graph (para redes sociales) -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="es_AR" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={image} />

		<!-- Tema -->
		<meta name="theme-color" content="#1a1a2e" />

		<!-- Schema.org JSON-LD (Datos Estructurados ENRIQUECIDOS) -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Locksmith",
				"name": "Cerrajeria DC",
				"image": "https://cerrajeriadc.com.ar/logo.png",
				"@id": "https://cerrajeriadc.com.ar/#locksmith",
				"url": "https://cerrajeriadc.com.ar",
				"telephone": "+5491170029897",
				"description": "Servicio de cerrajería profesional 24 horas en Buenos Aires, especializado en urgencias, aperturas y seguridad para hogares, autos y comercios.",
        "knowsAbout": [
          "Apertura de Puertas",
          "Cerrajería de Autos",
          "Apertura de Cajas Fuertes",
          "Cerrajería Comercial",
          "Puertas Blindadas",
          "Cambio de Cerraduras"
        ],
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "Bartolomé Mitre 3987",
					"addressLocality": "Ciudad Autónoma de Buenos Aires",
					"addressRegion": "CABA",
					"postalCode": "C1201AAW",
					"addressCountry": "AR"
				},
				"geo": {
					"@type": "GeoCoordinates",
					"latitude": "-34.60976108214114",
					"longitude": "-58.42256222049576"
				},
				"openingHoursSpecification": {
					"@type": "OpeningHoursSpecification",
					"dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
					"opens": "00:00",
					"closes": "23:59"
				},
				"priceRange": "$$",
				"areaServed": "Ciudad Autónoma de Buenos Aires",
				"hasOfferCatalog": {
					"@type": "OfferCatalog",
					"name": "Servicios de Cerrajería",
					"itemListElement": [
						{"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Urgencias Nocturnas 24hs"}},
						{"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Cerrajería Programada"}}
					]
				},
				"sameAs": [
					"https://maps.app.goo.gl/LFGparoHeiZ9Fheo8",
					"https://www.instagram.com/cerrajeriadc24hs"
				]
			}
		</script>
	</head>

	<body class="antialiased font-inter">
		<!-- Google Tag Manager (noscript) -->
		<noscript>
      <iframe
				src="https://www.googletagmanager.com/ns.html?id=GTM-TJNJQV5B"
				height="0"
				width="0"
				style="display:none;visibility:hidden">
      </iframe>
    </noscript>
		<!-- End Google Tag Manager (noscript) -->
		<main role="main">
			<slot />
		</main>
	</body>
</html>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const animatedElements = document.querySelectorAll(".animate-on-scroll");

		if (!("IntersectionObserver" in window)) {
			animatedElements.forEach((element) => {
				element.classList.remove("opacity-0");
			});
			return;
		}

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("is-visible");
						observer.unobserve(entry.target);
					}
				});
			},
			{
				threshold: 0.1,
			},
		);

		animatedElements.forEach((element) => {
			observer.observe(element);
		});
	});
</script>
