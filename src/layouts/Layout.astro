---
// Importaciones de fuentes y estilos globales
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "../styles/global.css";
import reviewsData from "../data/reviews.json";
import servicesData from "../data/services.json";

// Props para SEO dinámico
export interface Props {
	title?: string;
	description?: string;
	canonicalURL?: string;
	image?: string;
}

// Valores por defecto para las props
const {
	title = "Cerrajería 24 horas en Capital Federal | Cerrajería DC | Urgencia YA",
	description = "Servicio de cerrajeria de urgencia 24 horas en Capital Federal. Apertura de puertas, autos y cajas fuertes. ¡Llamanos ya!. ¡Llegamos en 20 minutos!",
	canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
	image = new URL("/logo.png", Astro.site).href,
} = Astro.props;

const siteUrl = Astro.site?.href ?? "https://cerrajeriadc.com.ar/";
const normalizedImage = image.startsWith("http")
	? image
	: new URL(image, siteUrl).href;

const ratingValue = 5;
const reviewCount = reviewsData.length;
const reviewSourcePublishers = {
	google: {
		"@type": "Organization",
		name: "Google",
		url: "https://www.google.com/",
	},
	instagram: {
		"@type": "Organization",
		name: "Instagram",
		url: "https://www.instagram.com/",
	},
	whatsapp: {
		"@type": "Organization",
		name: "WhatsApp",
		url: "https://www.whatsapp.com/",
	},
};

const schemaReviews = reviewsData.map((r) => {
	const review = {
		"@type": "Review",
		identifier: r.id,
		author: { "@type": r.authorType, name: r.name },
		reviewBody: r.review,
		datePublished: r.datePublished,
		reviewRating: {
			"@type": "Rating",
			ratingValue: r.stars,
			bestRating: ratingValue,
		},
		itemReviewed: {
			"@type": "Service",
			name: r.serviceType,
			areaServed: {
				"@type": "Place",
				name: r.location,
			},
		},
	};

	if (r.sourceUrl) {
		review.isPartOf = {
			"@type": "WebPage",
			name: `Reseña en ${r.source}`,
			url: r.sourceUrl,
		};
	}

	if (reviewSourcePublishers[r.source]) {
		review.publisher = reviewSourcePublishers[r.source];
	}

	return review;
});

const schemaServices = servicesData.map((s) => ({
	"@type": "Offer",
	itemOffered: {
		"@type": "Service",
		name: s.name,
		description: s.description,
	},
}));
---

