				"@id": "https://cerrajeriadc24hs.com/#locksmith",
				"url": "https://cerrajeriadc24hs.com",
				"telephone": "+5491170029897",
				"description": "Servicio de cerrajería profesional 24 horas en Buenos Aires",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "Bartolomé Mitre 3987",
					"addressLocality": "Ciudad Autónoma de Buenos Aires",
					"addressRegion": "CABA",
					"postalCode": "C1201AAW",
					"addressCountry": "AR"
				},
				"geo": {
					"@type": "GeoCoordinates",
					"latitude": "-34.60976108214114",
					"longitude": "-58.42256222049576"
				},
				"openingHoursSpecification": {
					"@type": "OpeningHoursSpecification",
					"dayOfWeek": [
						"Monday",
						"Tuesday",
						"Wednesday",
						"Thursday",
						"Friday",
						"Saturday",
						"Sunday"
					],
					"opens": "00:00",
					"closes": "23:59"
				},
				"priceRange": "$$",
				"areaServed": "Ciudad Autónoma de Buenos Aires",
				"hasOfferCatalog": {
					"@type": "OfferCatalog",
					"name": "Servicios de Cerrajería",
					"itemListElement": [
						{
							"@type": "Offer",
							"itemOffered": {
								"@type": "Service",
								"name": "Urgencias Nocturnas 24hs"
							}
						},
						{
							"@type": "Offer",
							"itemOffered": {
								"@type": "Service",
								"name": "Cerrajería Programada"
							}
						}
					]
				},
				"sameAs": [
					"https://maps.app.goo.gl/LFGparoHeiZ9Fheo8",
					"https://www.instagram.com/cerrajeriadc24hs"
				]
			}
		</script>
	</head>

	<body class="antialiased font-inter">
		<main role="main">
			<slot />
		</main>
	</body>
</html>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const animatedElements =
			document.querySelectorAll(".animate-on-scroll");

		if (!("IntersectionObserver" in window)) {
			animatedElements.forEach((element) => {
				element.classList.remove("opacity-0");
			});
			return;
		}

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("is-visible");
						observer.unobserve(entry.target);
					}
				});
			},
			{
				threshold: 0.1,
			},
		);

		animatedElements.forEach((element) => {
			observer.observe(element);
		});
	});
</script>
