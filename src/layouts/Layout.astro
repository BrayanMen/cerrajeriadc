			content="https://cerrajeriadc24hs.com/logo.png"
		/>

		<!-- Tema -->
		<meta name="theme-color" content="#1a1a2e" />

		<!-- Schema.org JSON-LD (Datos Estructurados) -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
