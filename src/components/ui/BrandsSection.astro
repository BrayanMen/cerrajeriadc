---
const brands = [
  "Mul-T-Lock", "Trabex", "Acytra", "Kallay", "Andif", "Prive",
  "Vanguard", "Yale", "Luber", "JDB", "Giacometti", "Candex", "ROA", "Currao"
];
---

<div class="py-12 bg-background">
  <div class="max-w-7xl mx-auto px-4">
     <div class="text-center mb-10 animate-on-scroll">
      <h2 class="text-sm uppercase text-muted-foreground tracking-widest">Confianza y Calidad Garantizada</h2>
      <p class="text-2xl font-semibold mt-2">Trabajamos con las Marcas Líderes del Mercado</p>
    </div>
  </div>

  <div class="animate-on-scroll w-full" style="animation-delay: 0.2s;">
    <div class="relative w-full overflow-hidden [mask-image:_linear-gradient(to_right,transparent_0,_black_10%,_black_90%,transparent_100%)]">
      <div class="flex w-max animate-scroll">
        {[...brands, ...brands].map(brand => (
          <div class="mx-10">
            <span class="text-2xl font-bold text-muted-foreground/50 hover:text-muted-foreground/80 transition-colors whitespace-nowrap cursor-default">{brand}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .animate-scroll {
    animation: scroll 45s linear infinite;
  }
</style>
