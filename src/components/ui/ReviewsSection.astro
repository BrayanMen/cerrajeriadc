---
import reviews from '../../data/reviews.json';
---
<section id="reviews" class="py-14 bg-secondary/30">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-12 animate-on-scroll">
        <h2 class="text-3xl md:text-5xl font-bold mb-4">Clientes <span class="text-gradient">satisfechos</span></h2>
        <p class="text-muted-foreground max-w-2xl mx-auto">Nuestras reseñas en Google hablan por sí solas. La satisfacción de nuestros clientes es nuestra máxima prioridad.</p>
      </div>
  
      <!-- Grid de Reseñas -->
      <div class="grid md:grid-cols-2 gap-6 animate-on-scroll" style="animation-delay: 0.2s;">
        {reviews.map(review => (
          <div class="bg-card p-6 rounded-lg glass-card">
            <div class="flex items-center mb-4">
              <div class="flex text-primary">
                <!-- Render stars based on the 'stars' property -->
                {Array(review.stars).fill(0).map(() => (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 7.09l6.572-.955L10 0l2.939 6.135 6.572.955-4.756 4.455 1.123 6.545z"/></svg>
                ))}
              </div>
            </div>
            <p class="text-muted-foreground mb-4">"{review.review}"</p>
            <p class="font-semibold">- {review.name}</p>
          </div>
        ))}
      </div>
  
      <!-- CTA -->
      <div class="text-center mt-12 animate-on-scroll" style="animation-delay: 0.4s;">
        <a href="https://maps.app.goo.gl/LFGparoHeiZ9Fheo8" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-primary text-black px-6 py-3 rounded-lg font-bold shadow-lg shadow-primary/30 hover:shadow-primary/50 hover:translate-y-1 transition-all">
          Leer más reseñas en Google
        </a>
      </div>
    </div>
  </section>