---
import Card from "../core/Card.astro";
import Button from "../core/Button.astro";
import residentialImage from "../../assets/services/cerrajeria-residencial.jpg";
import vehicleImage from "../../assets/services/apertura-vehiculos.jpg";
import safeImage from "../../assets/services/cajas-fuertes.jpg";
import commercialImage from "../../assets/services/cerrajeria-comercial.jpg";
import securityDoorImage from "../../assets/services/puertas-blindadas.jpg";
import blindexImage from "../../assets/services/vidrios-blindex.jpg";

const services = [
  {
    icon: "home",
    title: "Cerrajería Residencial",
    description: "Apertura de puertas de casas y departamentos. Cambio de cerraduras comunes y digitales.",
    features: ["Apertura sin daño", "Cerraduras multipunto", "Cerraduras digitales", "Puertas blindadas"],
    image: residentialImage,
    imageAlt: "Cerrajero instalando una cerradura en una puerta residencial.",
  },
  {
    icon: "car",
    title: "Apertura de Vehículos",
    description: "Abrimos tu auto sin dañar la cerradura ni la carrocería. Todas las marcas.",
    features: ["Sin dañar pintura", "Apertura en segundos", "Autos importados", "Todo tipo de vehiculos"],
    image: vehicleImage,
    imageAlt: "Herramientas de cerrajero para abrir la puerta de un coche.",
  },
  {
    icon: "safe",
    title: "Cajas Fuertes",
    description: "Apertura técnica de cajas fuertes. Cambio de combinación y mantenimiento.",
    features: ["Apertura de emergencia", "Cambio de clave", "Reparación", "Instalación"],
    image: safeImage,
    imageAlt: "Primer plano de un cerrajero abiendo una caja fuerte.",
  },
  {
    icon: "building",
    title: "Cerrajería Comercial",
    description: "Soluciones de seguridad para comercios y empresas.",
    features: ["Cerraduras antipánico", "Sistemas maestros", "Control de acceso", "Mantenimiento"],
    image: commercialImage,
    imageAlt: "Puerta de vidrio de una oficina con cerradura electrónica.",
  },
  {
    icon: "shield",
    title: "Puertas Blindadas",
    description: "Instalación y reparación de puertas blindadas y de seguridad.",
    features: ["Instalación completa", "Refuerzo de marco", "Cerraduras premium", "Alta seguridad"],
    image: securityDoorImage,
    imageAlt: "Puerta de seguridad blindada de alta resistencia.",
  },
  {
    icon: "key",
    title: "Vidrios Blindex",
    description: "Apertura y reparación de puertas Blindex y cerraduras especiales.",
    features: ["Cierra Puerta de piso", "Herrajes", "Puertas de Blidex", "Nivelación y Centrado"],
    image: blindexImage,
    imageAlt: "Puerta de vidrio tipo Blindex con su cerradura de piso.",
  },
];

const ctaOnclick = "window.dataLayer = window.dataLayer || []; window.dataLayer.push({'event': 'generacion_lead', 'lead_type': 'telefono', 'value': 1000});";
---

<section id="servicios" class="py-14 bg-secondary/30">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider mb-4 inline-block">
        Nuestros Servicios
      </span>
      <h2 class="text-3xl md:text-5xl font-bold mb-6">
        Solucionamos cualquier <span class="text-gradient">problema de cerrajería</span>
      </h2>
      <p class="text-muted-foreground max-w-2xl mx-auto">
        Más de 15 años de experiencia en apertura de puertas, vehículos y cajas fuertes en Capital Federal.
      </p>
    </div>

    <ul class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" aria-label="Servicios de cerrajería">
      {services.map((service, index) => (
        <div class="animate-on-scroll" style={`animation-delay: ${index * 0.1}s;`}>
          <Card
            title={service.title}
            description={service.description}
            image={service.image}
            imageAlt={service.imageAlt}
            features={service.features}
            icon={service.icon}
            ctaOnclick={ctaOnclick}
          />
        </div>
      ))}
    </ul>

    <div class="animate-on-scroll text-center mt-8" style="animation-delay: 0.6s;">
      <p class="text-muted-foreground mb-4">
        ¿No encontrás tu servicio? Consultanos sin compromiso
      </p>
      <Button href="tel:+5491170029897" onclick={ctaOnclick}>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.95.684l1.5 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.5a1 1 0 01.684.95V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        Llamar: +54 9 11 7002-9897
      </Button>
    </div>
  </div>
</section>