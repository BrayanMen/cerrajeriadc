---
import { Image } from "astro:assets";
import ServiceIcon from "../core/ServiceIcon.astro";
import residentialImage from "../../assets/services/cerrajeria-residencial.jpg";
import vehicleImage from "../../assets/services/apertura-vehiculos.jpg";
import safeImage from "../../assets/services/cajas-fuertes.jpg";
import commercialImage from "../../assets/services/cerrajeria-comercial.jpg";
import securityDoorImage from "../../assets/services/puertas-blindadas.jpg";
import blindexImage from "../../assets/services/vidrios-blindex.jpg";

const services = [
  {
    icon: "home",
    title: "Cerrajería Residencial",
    description: "Apertura de puertas de casas y departamentos. Cambio de cerraduras comunes y digitales.",
    features: ["Apertura sin daño", "Cerraduras multipunto", "Cerraduras digitales", "Puertas blindadas"],
    image: residentialImage, // Usando imagen local optimizada
    imageAlt: "Cerrajero instalando una cerradura en una puerta residencial.",
  },
  {
    icon: "car",
    title: "Apertura de Vehículos",
    description: "Abrimos tu auto sin dañar la cerradura ni la carrocería. Todas las marcas.",
    features: ["Sin dañar pintura", "Apertura en segundos", "Autos importados", "Todo tipo de vehiculos"],
    image: vehicleImage, // Usando imagen local optimizada
    imageAlt: "Herramientas de cerrajero para abrir la puerta de un coche.",
  },
  {
    icon: "safe",
    title: "Cajas Fuertes",
    description: "Apertura técnica de cajas fuertes. Cambio de combinación y mantenimiento.",
    features: ["Apertura de emergencia", "Cambio de clave", "Reparación", "Instalación"],
    image: safeImage, // Usando imagen local optimizada
    imageAlt: "Primer plano de un cerrajero abiendo una caja fuerte.",
  },
  {
    icon: "building",
    title: "Cerrajería Comercial",
    description: "Soluciones de seguridad para comercios y empresas.",
    features: ["Cerraduras antipánico", "Sistemas maestros", "Control de acceso", "Mantenimiento"],
    image: commercialImage, // Usando imagen local optimizada
    imageAlt: "Puerta de vidrio de una oficina con cerradura electrónica.",
  },
  {
    icon: "shield",
    title: "Puertas Blindadas",
    description: "Instalación y reparación de puertas blindadas y de seguridad.",
    features: ["Instalación completa", "Refuerzo de marco", "Cerraduras premium", "Alta seguridad"],
    image: securityDoorImage, // Usando imagen local optimizada
    imageAlt: "Puerta de seguridad blindada de alta resistencia.",
  },
  {
    icon: "key",
    title: "Vidrios Blindex",
    description: "Apertura y reparación de puertas Blindex y cerraduras especiales.",
    features: ["Cierra Puerta de piso","Herrajes", "Puertas de Blidex", "Nivelación y Centrado"],
    image: blindexImage, // Usando imagen local optimizada
    imageAlt: "Puerta de vidrio tipo Blindex con su cerradura de piso.",
  },
];
---
<section id="servicios" class="py-14 bg-secondary/30">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider mb-4 inline-block">
          Nuestros Servicios
        </span>
        <h2 class="text-3xl md:text-5xl font-bold mb-6">
          Solucionamos cualquier <span class="text-gradient">problema de cerrajería</span>
        </h2>
        <p class="text-muted-foreground max-w-2xl mx-auto">
          Más de 15 años de experiencia en apertura de puertas, vehículos y cajas fuertes en Capital Federal.
        </p>
      </div>
  
      <!-- Grid -->
      <div
      class="grid md:grid-cols-2 lg:grid-cols-3 gap-6"
      role="list"
      aria-label="Servicios de cerrajería"
    >
      {services.map((service, index) => (
        <article
          class="animate-on-scroll relative group overflow-hidden rounded-2xl glass-card transition-all hover:-translate-y-1 hover:border-primary/50"
          style={`animation-delay: ${index * 0.1}s;`}
          role="listitem"
          aria-labelledby={`service-title-${index}`}
          aria-describedby={`service-desc-${index}`}
        >
    
          <!-- Imagen de fondo -->
          <Image
            src={service.image}
            alt={service.imageAlt}
            width={400}
            height={400}
            format="webp"
            quality={80}
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover z-0"
          />
    
          <!-- Overlay para legibilidad -->
          <div
            class="absolute inset-0 bg-black/70 backdrop-blur-[2px] z-0"
            aria-hidden="true"
          ></div>
    
          <!-- Contenido -->
          <div class="relative z-10 p-6 text-white">
    
            <!-- Icono principal -->
            <div
              class="w-12 h-12 bg-primary/80 rounded-xl flex items-center justify-center mb-4"
              aria-hidden="true"
            >
              <ServiceIcon name={service.icon} />
            </div>
    
            <!-- Icono decorativo -->
            <div
              class="absolute top-4 right-4 opacity-10 group-hover:opacity-20 transition-opacity"
              aria-hidden="true"
            >
              <ServiceIcon name={service.icon} size={72} />
            </div>
    
            <h3
              id={`service-title-${index}`}
              class="text-xl font-bold mb-3"
            >
              {service.title}
            </h3>
    
            <p
              id={`service-desc-${index}`}
              class="text-sm mb-4 leading-relaxed text-white/90"
            >
              {service.description}
            </p>
    
            <ul class="space-y-2 mb-6" aria-label="Características del servicio">
              {service.features.map((feature) => (
                <li class="flex items-center gap-2 text-sm">
                  <span
                    class="w-1.5 h-1.5 bg-primary rounded-full"
                    aria-hidden="true"
                  ></span>
                  {feature}
                </li>
              ))}
            </ul>
    
            <a
              href="tel:+5491170029897"
              class="inline-flex items-center font-semibold text-primary hover:text-primary/90 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded"
              aria-label={`Llamar para consultar sobre ${service.title}`}
            >
              Consultar ahora
              <span class="ml-2 transition-transform group-hover:translate-x-1">→</span>
            </a>
    
          </div>
        </article>
      ))}
    </div>
  
      <!-- CTA -->
      <div class="animate-on-scroll text-center mt-8" style="animation-delay: 0.6s;">
        <p class="text-muted-foreground mb-4">
          ¿No encontrás tu servicio? Consultanos sin compromiso
        </p>
        <a href="tel:+5491170029897" class="inline-flex items-center gap-3 bg-primary text-black px-3 py-2 rounded-lg font-bold shadow-lg shadow-primary/30 hover:shadow-primary/50 hover:translate-y-1 transition-all">
            <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 3.1 5.18 2 2 0 0 1 5 3h3a2 2 0 0 1 2 1.72l.5 3a2 2 0 0 1-.57 1.73L8.09 11a16 16 0 0 0 6.91 6.91l1.55-1.55a2 2 0 0 1 1.73-.57l3 .5A2 2 0 0 1 22 16.92z"
            ></path>
          </svg> Llamar: +54 9 11 7002-9897
        </a>
      </div>
    </div>
  </section>
  