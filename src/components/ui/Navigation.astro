---
const navLinks = [
  { href: "#servicios", label: "Servicios" },
  { href: "#testimonials", label: "Testimonios" },
  { href: "#location", label: "Ubicacion" },
  { href: "#faq", label: "Preguntas" },
  // { href: "#urgencias", label: "Urgencias 24/7" },
];
---

<div class="bg-primary text-black py-2 px-4 text-center text-sm font-bold">
  <div class="flex items-center justify-center gap-4 flex-wrap">
    <span>Servicio 24 horas - 365 días del año</span>
    <span class="hidden md:inline">|</span>
    <a
      href="tel:+5491170029897"
      onclick="window.dataLayer = window.dataLayer || []; window.dataLayer.push({
    'event': 'generacion_lead',
    'lead_type': 'telefono',
    'value': 1000
  });"
      class="hover:underline"
    >
      +54 9 11 7002-9897
    </a>
  </div>
</div>

<nav
  id="main-nav"
  class="sticky top-0 z-50 transition-all duration-300 bg-background/10 backdrop-blur-sm"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <a href="/" class="flex items-center gap-2" aria-label="Página de inicio">
        <div class="hidden sm:block">
          <span class="text-xl font-bold">Cerrajería DC</span>
          <span class="block text-xs text-primary font-semibold">24 HORAS</span>
        </div>
      </a>

      <div class="hidden lg:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-gray-200 hover:text-primary transition-colors font-medium text-sm"
            >
              {link.label}
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-3">
        <a
          href="https://wa.me/5491170029897?text=Hola%2C%20necesito%20un%20cerrajero%20urgente"
          target="_blank"
          onclick="window.dataLayer = window.dataLayer || []; window.dataLayer.push({
    'event': 'generacion_lead',
    'lead_type': 'whatsapp',
    'value': 1000
  });"
          class="flex p-2 border border-green-400 rounded-full hover:bg-green-400/40 text-sm"
          aria-label="Contactar por WhatsApp"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            fill="currentColor"
            class="bi bi-whatsapp"
            viewBox="0 0 16 16"
            aria-hidden="true"
          >
            <path
              d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"
            ></path>
          </svg>
        </a>

        <a
          href="tel:+5491170029897" 
          onclick="window.dataLayer = window.dataLayer || []; window.dataLayer.push({
    'event': 'generacion_lead',
    'lead_type': 'telefono',
    'value': 1000
  });"
          class="px-3 py-2 flex bg-primary text-black rounded-md text-sm font-bold animate-pulse"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5 mx-1"
            aria-hidden="true"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 3.1 5.18 2 2 0 0 1 5 3h3a2 2 0 0 1 2 1.72l.5 3a2 2 0 0 1-.57 1.73L8.09 11a16 16 0 0 0 6.91 6.91l1.55-1.55a2 2 0 0 1 1.73-.57l3 .5A2 2 0 0 1 22 16.92z"
            ></path>
          </svg> Llamar ahora
        </a>

        <button
          id="menu-btn"
          class="lg:hidden px-2 py-2"
          aria-label="Abrir menú"
        >
          ☰
        </button>
      </div>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-background border-t border-border"
  >
    <div class="px-4 py-4 space-y-2">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="block px-4 py-3 rounded-lg hover:bg-secondary"
          >
            {link.label}
          </a>
        ))
      }

      <div class="pt-4 border-t border-border">
        <a
          href="https://wa.me/5491170029897?text=Hola%2C%20necesito%20un%20cerrajero%20urgente"
          target="_blank"
          onclick="window.dataLayer = window.dataLayer || []; window.dataLayer.push({
    'event': 'generacion_lead',
    'lead_type': 'whatsapp',
    'value': 1000
  });"
          class="block text-center px-4 py-3 border rounded-lg"
        >
          WhatsApp
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById("main-nav");
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  if (nav) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        nav.classList.add(
          "shadow-lg",
          "border-b",
          "border-border",
          "bg-background/95",
        );
      } else {
        nav.classList.remove(
          "shadow-lg",
          "border-b",
          "border-border",
          "bg-background/95",
        );
      }
    });
  }

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener("click", () => {
      mobileMenu.classList.toggle("hidden");
    });
  }
</script>
