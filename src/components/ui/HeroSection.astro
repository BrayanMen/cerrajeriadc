<section
  id="hero"
  class="relative flex items-center justify-center overflow-hidden min-h-screen"
>
  <div
    class="absolute inset-0 bg-gradient-to-br from-background via-background to-secondary/50"
  >
  </div>

  <!-- Animated background elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div
      class="absolute top-20 left-10 w-72 h-72 bg-primary/20 rounded-full blur-3xl animate-float"
    >
    </div>
    <div
      class="absolute bottom-10 right-10 w-96 h-96 bg-primary/15 rounded-full blur-3xl animate-float"
      style="animation-delay: 1s;"
    >
    </div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto py-16 md:py-24">
    <div class="text-center">
      <!-- Main Title (SINGLE H1) -->
      <h1
        class="animate-on-scroll opacity-0 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6"
        style="animation-delay: 0.1s;"
      >
        <span class="block text-foreground">Cerrajería a Domicilio 24/7</span>
        <span class="block text-gradient mt-2">Urgencias en CABA</span>
      </h1>

      <!-- Stylish paragraph instead of H1 -->
      <div
        class="animate-on-scroll opacity-0 inline-flex items-center gap-2 bg-primary/10 border border-primary/30 rounded-full px-4 py-2 mb-8"
      >
        <span class="relative flex h-3 w-3">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"
          ></span>
          <span class="relative inline-flex bg-green-500 rounded-full h-3 w-3"
          ></span>
        </span>
        <p class="text-primary font-semibold text-xs sm:text-sm">
          Cerrajero disponible ahora – Emergencias 24hs
        </p>
      </div>

      <!-- Descriptive Subtitle (H2) -->
      <h2
        class="animate-on-scroll opacity-0 text-base sm:text-lg md:text-xl text-muted-foreground max-w-3xl mx-auto mb-8"
        style="animation-delay: 0.2s;"
      >
        Apertura de puertas, autos y cajas fuertes en Capital Federal.
        <span class="text-primary font-semibold"> Llegamos en minutos.</span>
        Sin daños. Presupuesto sin cargo.
      </h2>

      <!-- CTA -->
      <div
        class="animate-on-scroll opacity-0 flex flex-col sm:flex-row items-center justify-center gap-4 mb-12"
        style="animation-delay: 0.3s;"
      >
        <a
          href="tel:+5491170029897"
          aria-label="Llamar Ahora"
          onclick="window.dataLayer = window.dataLayer || []; window.dataLayer.push({
    'event': 'generacion_lead',
    'lead_type': 'telefono',
    'value': 1000
  });"
          class="w-full sm:w-auto"
        >
          <button
            class="w-full sm:w-auto text-base sm:text-lg px-6 py-3 text-black gap-3 bg-primary rounded-lg shadow-lg animate-pulse-glow flex items-center justify-center"
          >
