      >
        <div class="marquee-container flex items-center">
          <div
            class="marquee-content font-display text-white font-bold text-lg sm:text-2xl md:text-4xl uppercase tracking-widest"
          >
            &nbsp;•&nbsp; APERTURA INMEDIATA &nbsp;•&nbsp; 15/30 MIN TIEMPO DE
