<section class="border-y border-white/10 overflow-hidden">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
    <div
      class="p-8 md:p-12 flex flex-col justify-between h-40 sm:h-48 group hover:bg-white/5 transition-colors cursor-default border-b sm:border-b-0 sm:border-r border-white/10"
    >
      <span class="text-base sm:text-lg uppercase tracking-widest text-gray-300"
        >Experiencia</span
      >
      <span
        class="text-4xl sm:text-5xl md:text-7xl font-thin group-hover:text-primary transition-colors"
        >20+</span
      >
    </div>
    <div
      class="p-8 md:p-12 flex flex-col justify-between h-40 sm:h-48 group hover:bg-white/5 transition-colors cursor-default border-b sm:border-b-0 lg:border-r border-white/10"
    >
      <span class="text-base sm:text-lg uppercase tracking-widest text-gray-300"
        >Respuesta</span
      >
      <span
        class="text-4xl sm:text-5xl md:text-7xl font-thin group-hover:text-primary transition-colors"
        >24/7</span
      >
    </div>
    <div
      class="p-8 md:p-12 flex flex-col justify-between h-40 sm:h-48 group hover:bg-white/5 transition-colors cursor-default border-b sm:border-b-0 sm:border-r border-white/10"
    >
      <span class="text-base sm:text-lg uppercase tracking-widest text-gray-300"
        >Cobertura</span
      >
      <span
        class="text-4xl sm:text-5xl md:text-7xl font-thin group-hover:text-primary transition-colors"
        >100%</span
      >
    </div>
    <div
      class="p-8 md:p-12 flex flex-col justify-center h-40 sm:h-48 bg-primary hover:bg-primary/90 transition-colors"
    >
      <a
        href="tel:+5491170029897"
        class="w-full flex items-center justify-between"
      >
        <div>
          <span
            class="text-base sm:text-lg font-semibold uppercase tracking-widest text-black"
            >Urgencias</span
          >
          <span class="block text-2xl sm:text-3xl text-black font-bold"
            >Llamar Ahora</span
          >
        </div>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-12 w-12 transform text-black -rotate-5"
        >
