---
interface Props {
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  href?: string;
  onclick?: string;
  class?: string;
}

const {
  variant = "primary",
  size = "md",
  href,
  onclick,
  class: className = "",
} = Astro.props;

const baseStyles = "inline-flex items-center justify-center font-semibold transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-lg cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed";

const variants = {
  primary: "bg-primary text-black hover:bg-primary/90 shadow-lg shadow-primary/30 hover:shadow-primary/50 hover:translate-y-1",
  secondary: "bg-transparent border border-primary text-primary hover:bg-primary/10",
  ghost: "bg-transparent text-foreground hover:text-primary",
};

const sizes = {
  sm: "px-3 py-1.5 text-sm gap-1.5",
  md: "px-4 py-2 text-base gap-2",
  lg: "px-6 py-3 text-lg gap-3",
};

const styles = `${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`;
---

{href ? (
  <a href={href} class={styles} onclick={onclick}>
    <slot />
  </a>
) : (
  <button class={styles} onclick={onclick}>
    <slot />
  </button>
)}